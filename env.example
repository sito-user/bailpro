# ============================================================
# BailPro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env dans Git
# ============================================================

# Environnement
NODE_ENV=development

# Serveur
PORT=3000

# Base de données
DATABASE_URL=postgresql://bailpro:bailpro_dev@localhost:5432/bailpro_dev
DATABASE_TEST_URL=postgresql://bailpro:bailpro_dev@localhost:5432/bailpro_test

# JWT
JWT_SECRET=remplacer_par_une_chaine_aleatoire_256_bits
JWT_EXPIRES_IN=7d

# CORS (URL du frontend)
CORS_ORIGIN=http://localhost:5173

# Upload (quittances PDF)
UPLOAD_DIR=uploads/receipts
